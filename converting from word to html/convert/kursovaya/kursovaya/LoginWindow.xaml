
<!-- Окно входа в приложение "Конвертер DOCX в HTML" -->
<Window x:Class="DocxToHtmlConverter.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конвертер DOCX в HTML - Вход" 
        Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF0F5F5">
    <!-- Основной контейнер -->
    <Grid>
        <!-- Вертикальный стек для элементов интерфейса -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <!-- Логотип приложения (иконка) -->
            <Viewbox Width="200" Height="200" Margin="0,0,0,20">
                <Canvas Width="24" Height="24">
                    <Path Fill="#FF4CAF50" Data="M19,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z M8.5,6c0.8,0,1.5,0.7,1.5,1.5S9.3,9,8.5,9S7,8.3,7,7.5S7.7,6,8.5,6z M18,16H6v-1.5h12V16z M18,12H6v-1.5h12V12z"/>
                </Canvas>
            </Viewbox>

            <!-- Название приложения -->
            <TextBlock Text="DOCX to HTML Converter" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="#FF2E5E6E"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- Описание приложения -->
            <TextBlock Text="Профессиональный конвертер документов Word в HTML" 
                       FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,40"
                       TextAlignment="Center" Foreground="#FF7EB6C7"/>

            <!-- Кнопка "Начать работу" -->
            <Button x:Name="StartButton" Content="Начать работу" 
                    HorizontalAlignment="Center" Padding="20,10" 
                    Click="StartButton_Click"
                    Background="#FF4CAF50" Foreground="White"
                    BorderBrush="#FF45A049" BorderThickness="1"
                    FontSize="16" FontWeight="Bold">
                <!-- Стиль для скругления углов кнопки -->
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
