<!-- Главное окно приложения "Конвертер DOCX в HTML" -->
<Window x:Class="DocxToHtmlConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конвертер DOCX в HTML" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F5F5">
    <!-- Основной контейнер с отступами -->
    <Grid Margin="15">
        <!-- Определение строк сетки -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Поле выбора файла -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопка конвертации -->
            <RowDefinition Height="*"/>
            <!-- Метаданные документа -->
            <RowDefinition Height="Auto"/>
            <!-- Нижняя панель с кнопками -->
        </Grid.RowDefinitions>

        <!-- Заголовок окна -->
        <TextBlock Grid.Row="0" Text="Конвертер DOCX в HTML" 
                   FontSize="18" FontWeight="Bold"
                   Foreground="#FF2E5E6E" Margin="0,0,0,15"/>

        <!-- Поле выбора файла -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Текстовое поле -->
                <ColumnDefinition Width="Auto"/>
                <!-- Кнопка "Обзор" -->
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilePathTextBox" Grid.Column="0" 
                     Background="White" BorderBrush="#FF7EB6C7" 
                     BorderThickness="1" Padding="8"
                     VerticalContentAlignment="Center">
                <!-- Стиль для скругления углов текстового поля -->
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            <Button Grid.Column="1" Content="Обзор..." 
                    Width="100" Margin="10,0,0,0"
                    Click="BrowseButton_Click"
                    Background="#FF4CAF50" Foreground="White"
                    BorderBrush="#FF45A049" BorderThickness="1"
                    Padding="8">
                <!-- Стиль для скругления углов кнопки -->
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Кнопка конвертации -->
        <Button x:Name="ConvertButton" Grid.Row="2" 
                Content="Конвертировать в HTML" 
                HorizontalAlignment="Center" 
                Padding="15,8" Margin="0,15"
                Click="ConvertButton_Click"
                Background="#FF2196F3" Foreground="White"
                BorderBrush="#FF1976D2" BorderThickness="1"
                FontWeight="Bold">
            <!-- Стиль для скругления углов кнопки -->
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Button.Resources>
        </Button>

        <!-- Прогресс-бар (скрыт по умолчанию) -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="2" 
                     Height="6" Margin="0,0,0,10" 
                     VerticalAlignment="Bottom" 
                     IsIndeterminate="True" 
                     Visibility="Collapsed"
                     Foreground="#FF2196F3">
            <!-- Стиль для скругления углов прогресс-бара -->
            <ProgressBar.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="3"/>
                </Style>
            </ProgressBar.Resources>
        </ProgressBar>

        <!-- Группа для метаданных документа -->
        <GroupBox Grid.Row="3" Header="Метаданные документа" 
                  Margin="0,15" Padding="10"
                  Background="#FFE8F4F8" BorderBrush="#FF7EB6C7"
                  Foreground="#FF2E5E6E" FontWeight="Bold">
            <!-- Текстовое поле для отображения метаданных -->
            <TextBox x:Name="MetadataTextBox" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Disabled"
                     TextWrapping="Wrap" FontFamily="Consolas"
                     Background="White" BorderBrush="#FF7EB6C7"
                     Padding="8">
                <!-- Стиль для скругления углов текстового поля -->
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </GroupBox>

        <!-- Нижняя панель с кнопками -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <!-- Кнопка "Выход" -->
            <Button x:Name="LogoutButton" Content="Выход" 
                    Width="100" Margin="0,0,10,0"
                    Click="LogoutButton_Click"
                    Background="#FF607D8B" Foreground="White"
                    BorderBrush="#FF455A64" BorderThickness="1"
                    Padding="8">
                <!-- Стиль для скругления углов кнопки -->
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <!-- Кнопка "Готово" -->
            <Button x:Name="DoneButton" Content="Готово" 
                    Width="100"
                    Click="DoneButton_Click"
                    Background="#FF607D8B" Foreground="White"
                    BorderBrush="#FF455A64" BorderThickness="1"
                    Padding="8">
                <!-- Стиль для скругления углов кнопки -->
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>