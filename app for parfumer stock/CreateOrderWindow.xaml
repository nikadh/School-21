<Window x:Class="PerfumeWarehouseWPF.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый заказ" Height="800" Width="1200"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с кнопкой авторского набора -->
        <Border Grid.Row="0" Background="Black" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Выберите товары для заказа" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Собрать авторский набор" Margin="20,0,0,0" Click="CustomSetButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Основная область: каталог и корзина -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Каталог товаров -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CatalogItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Margin="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="220" Margin="5" Padding="5" BorderBrush="LightGray" 
                                        BorderThickness="1" CornerRadius="5">
                                    <StackPanel>
                                        <Image Source="{Binding ImageSource}" Height="120" Width="120" 
                                               Stretch="Uniform" Margin="0,5"/>
                                        <TextBlock Text="{Binding ProductName}" FontWeight="Bold" 
                                                   TextWrapping="Wrap" HorizontalAlignment="Center"/>

                                        <!-- Выбор объёма -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                                            <RadioButton Content="60 мл" IsChecked="{Binding IsVolume60Selected}" 
                                                         GroupName="{Binding VolumeGroupName}" Margin="3,0"/>
                                            <RadioButton Content="120 мл" IsChecked="{Binding IsVolume120Selected}" 
                                                         GroupName="{Binding VolumeGroupName}" Margin="3,0"/>
                                        </StackPanel>

                                        <!-- Цена -->
                                        <TextBlock Text="{Binding DisplayPrice}" FontWeight="Bold" 
                                                   Foreground="Green" HorizontalAlignment="Center"/>

                                        <!-- Остаток -->
                                        <TextBlock Text="{Binding StockInfo}" FontSize="11" 
                                                   Foreground="{Binding StockColor}" HorizontalAlignment="Center" Margin="0,2"/>

                                        <!-- Количество -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                            <TextBlock Text="Кол-во:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Quantity}" Width="50" Height="25"
                                                     PreviewTextInput="QuantityTextBox_PreviewTextInput"/>
                                        </StackPanel>

                                        <!-- Кнопка добавить в корзину -->
                                        <Button Content="В корзину" Margin="0,5" Click="AddToCartButton_Click" 
                                                Tag="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Корзина -->
            <Border Grid.Column="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Корзина" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ListBox x:Name="CartListBox" Grid.Row="1" DisplayMemberPath="DisplayText"/>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock x:Name="TotalAmountText" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Button Content="Оформить заказ" Height="35" Click="CheckoutButton_Click"/>
                        <Button Content="Очистить корзину" Margin="0,5,0,0" Click="ClearCartButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Кнопка закрыть -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Margin="10">
            <Button Content="Закрыть" Width="100" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>