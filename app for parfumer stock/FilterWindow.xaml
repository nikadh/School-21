<Window x:Class="PerfumeWarehouseWPF.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фильтры" Height="700" Width="450"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

      

        <!-- Объём -->
        <GroupBox Grid.Row="0" Header="Объём" Margin="0,0,0,10">
            <StackPanel>
                <CheckBox x:Name="Volume60CheckBox" Content="60 мл" Margin="5"/>
                <CheckBox x:Name="Volume120CheckBox" Content="120 мл" Margin="5"/>
            </StackPanel>
        </GroupBox>

        <!-- Содержание спирта -->
        <GroupBox Grid.Row="1" Header="Содержание спирта (%)" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="От:" Width="30"/>
                    <TextBox x:Name="MinAlcoholTextBox" Width="60" Text="0"/>
                    <TextBlock Text="%" Margin="5,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="До:" Width="30"/>
                    <TextBox x:Name="MaxAlcoholTextBox" Width="60" Text="100"/>
                    <TextBlock Text="%" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Остаток на складе -->
        <GroupBox Grid.Row="2" Header="Остаток на складе (шт.)" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="От:" Width="30"/>
                    <TextBox x:Name="MinStockTextBox" Width="60" Text="0"/>
                    <TextBlock Text="шт." Margin="5,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="До:" Width="30"/>
                    <TextBox x:Name="MaxStockTextBox" Width="60" Text="9999"/>
                    <TextBlock Text="шт." Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Цена -->
        <GroupBox Grid.Row="3" Header="Цена (₽)" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="От:" Width="30"/>
                    <TextBox x:Name="MinPriceTextBox" Width="80" Text="0"/>
                    <TextBlock Text="₽" Margin="5,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="До:" Width="30"/>
                    <TextBox x:Name="MaxPriceTextBox" Width="80" Text="999999"/>
                    <TextBlock Text="₽" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Ноты -->
        <GroupBox Grid.Row="4" Header="Ноты (выберите нужные)" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock Text="Поиск ноты:" Margin="0,0,5,0"/>
                <TextBox x:Name="NoteSearchTextBox" Width="150" TextChanged="NoteSearchTextBox_TextChanged"/>
            </DockPanel>
        </GroupBox>

        <ListBox Grid.Row="5" x:Name="NotesListBox" SelectionMode="Multiple" Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding NoteName}" Width="120"/>
                        <TextBlock Text="{Binding NoteType}" Foreground="Gray"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Применить" Width="80" Margin="0,0,10,0" Click="ApplyButton_Click"/>
            <Button Content="Сбросить" Width="80" Margin="0,0,10,0" Click="ResetButton_Click"/>
            <Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>