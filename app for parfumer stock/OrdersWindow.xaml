<Window x:Class="PerfumeWarehouseWPF.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказы" Height="650" Width="850"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список заказов" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Поиск и обновление -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск по номеру:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="SearchTextBox" Width="120" Height="25" VerticalAlignment="Center"/>
            <Button Content="Найти" Width="60" Margin="10,0,0,0" Click="SearchButton_Click"/>
            <Button Content="Сбросить" Width="70" Margin="5,0,0,0" Click="ResetButton_Click"/>
        </StackPanel>

        <!--  список заказов и детали -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Список заказов -->
            <ListBox x:Name="OrdersListBox" Grid.Column="0" Margin="0,0,5,0"
                     SelectionChanged="OrdersListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" FontSize="14" Padding="5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Детали заказа -->
            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Детали заказа" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Клиент -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,5">
                        <TextBlock Text="Клиент:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CustomerInfoText"/>
                    </StackPanel>

                    <!-- Статус -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,5">
                        <TextBlock Text="Статус:" FontWeight="SemiBold"/>
                        <ComboBox x:Name="StatusComboBox" DisplayMemberPath="StatusName" 
                                  SelectedValuePath="StatusID" Width="200" Height="25"/>
                    </StackPanel>

                    <!-- Сумма -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,5">
                        <TextBlock Text="Сумма:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalAmountText"/>
                    </StackPanel>

                    <!-- Комментарий -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,5">
                        <TextBlock Text="Комментарий:" FontWeight="SemiBold"/>
                        <TextBox x:Name="CommentTextBox" Width="300" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- Кнопки изменения -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,10,0,5">
                        <Button Content="Сохранить статус" Width="130" Margin="0,0,10,0" Click="SaveStatusButton_Click"/>
                        <Button Content="Сохранить комментарий" Width="160" Click="SaveCommentButton_Click"/>
                    </StackPanel>

                    <!-- Товары в заказе -->
                    <TextBlock Grid.Row="6" Text="Товары:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                    <ScrollViewer Grid.Row="7" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="OrderItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='{}x{0}'}" Margin="10,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat='N0 ₽'}" Width="80" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Кнопки внизу -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Обновить" Width="100" Margin="5" Click="RefreshButton_Click"/>
            <Button Content="Закрыть" Width="100" Margin="5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>