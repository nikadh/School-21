<Window x:Class="PerfumeWarehouseWPF.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация сотрудника" Height="600" Width="500"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новый сотрудник" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="350" HorizontalAlignment="Center">
                <TextBlock Text="Фамилия*" Margin="0,5"/>
                <TextBox x:Name="LastNameTextBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Имя*" Margin="0,5"/>
                <TextBox x:Name="FirstNameTextBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Отчество" Margin="0,5"/>
                <TextBox x:Name="MiddleNameTextBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Паспорт (серия и номер)*" Margin="0,5"/>
                <TextBox x:Name="PassportTextBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Телефон" Margin="0,5"/>
                <TextBox x:Name="PhoneTextBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Email*" Margin="0,5"/>
                <TextBox x:Name="EmailTextBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Логин*" Margin="0,5"/>
                <TextBox x:Name="LoginTextBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Пароль*" Margin="0,5"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10" Height="28"/>

                <TextBlock Text="Повторите пароль*" Margin="0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,15" Height="28"/>

                <TextBlock x:Name="ErrorMessage" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="RegisterButton" Content="Зарегистрировать" Width="120" Height="35" Margin="5" Click="RegisterButton_Click"/>
            <Button Content="Отмена" Width="120" Height="35" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>