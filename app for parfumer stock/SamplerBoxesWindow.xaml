<Window x:Class="PerfumeWarehouseWPF.SamplerBoxesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подарочные наборы" Height="600" Width="900"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Подарочные наборы Mancera" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BoxesItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Margin="10" Padding="10" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <Image Source="{Binding ImageSource}" Height="150" Width="150" Stretch="Uniform" Margin="0,5"/>
                                <TextBlock Text="{Binding BoxName}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,5"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,5"/>
                                <TextBlock Text="{Binding PriceText}" FontSize="16" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Center" Margin="0,5"/>
                                <TextBlock Text="{Binding StockText}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding StockColor}" Margin="0,2"/>
                                <Expander Header="Состав набора" Margin="0,5" IsExpanded="False">
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayText}" FontSize="11" Margin="2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Обновить" Width="100" Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>